            "categories": {
                "music": "🎵 Music",
                "economy": "💰 Economy",
                "xp": "⭐ Experience",
                "config": "⚙️ Configuration",
                "fun": "🎮 Fun",
                "utility": "🛠️ Utility"
            },
            "specific_command": {
                "title": "Help: /{command}",
