                "channel": {
                    "name": "channel",
                    "description": "Channel to be set"
                }
            }
        },
        "addxprole": {
            "name": "addxprole",
            "description": "Set the roles given on reaching certain amount of XP.",
            "options": {
                "role": {
                    "name": "role",
                    "description": "Role that will be given."
                },
                "level": {
                    "name": "level",
                    "description": "Level that the role represents."
                },
                "xp": {
                    "name": "xp",
                    "description": "Necessary amount of XP."
                }
            },
            "response": {
                "title": "XP Role",
                "role_already_exists": "This role is already set as a XP role.",
                "role_setup": "Role **{role}** Added for level **{level}** (**{xp}xp**)."
            }
        },
        "listxproles": {
            "name": "listxproles",
            "description": "Lists all XP reward roles configured on this server.",
            "response": {
                "title": "XP roles",
                "empty": "No XP roles are configured. Use `/addxprole` to add one.",
                "line": "• {role} — level **{level}** — **{xp}** XP",
                "truncated": "(list truncated — too many roles)"
            }
        },
        "editxprole": {
            "name": "editxprole",
            "description": "Changes the XP (and optionally the level) for an XP role in the database.",
            "options": {
                "xp": {
                    "description": "New XP threshold required for this role."
                },
                "level": {
                    "description": "New level label (optional; keeps current if omitted)."
                }
            },
            "response": {
                "title": "XP role updated",
                "body": "{role}: level **{level}**, **{xp}** XP.",
                "hint": "To apply Discord roles based on each member's XP, run **sync XP roles** (`/syncxproles`)."
            },
            "errors": {
                "not_configured": "This role is not set as an XP role. Use `/addxprole` first.",
                "save_failed": "Could not save the change. Check the logs."
            }
        },
        "syncxproles": {
            "name": "syncxproles",
            "description": "Recalculates and applies XP roles to all members with bot records in this server.",
            "response": {
                "title": "XP role sync",
                "started": "Processing **{pending}** members with bot records. This may take several minutes.\n\nYou'll get a **private** follow-up when it's done.",
