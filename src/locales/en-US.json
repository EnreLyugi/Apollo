                "empty": "No one has XP records in this server — nothing to sync."
            },
            "errors": {
                "sync_failed": "Something went wrong while syncing roles. Check the logs.",
                "followup_expired": "Sync took too long to send the summary (Discord limit). Check the bot logs."
            }
        },
