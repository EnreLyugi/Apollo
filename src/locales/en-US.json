            "usage": "/setchannel <channel type> <channel>",
            "options": {
                "channeltype": {
                    "name": "channeltype",
                    "description": "Type of the channel to be set",
                    "choices": {
                        "welcome_channel": {
                            "name": "Welcome Channel"
                        },
                        "birthday_channel": {
                            "name": "Birthday Notification Channel"
                        },
                        "voice_activity_log_channel": {
                            "name": "Call logs Channel"
