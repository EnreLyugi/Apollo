        "xp": {
            "name": "xp",
            "description": "Shows your current XP in the server",
            "current_xp": "Your current XP: {serverXp}",
            "usage": "/xp"
        },
        "xpuser": {
            "name": "xp",
            "description": "General XP commands (rank, etc)",
            "usage": "/xp [action]",
            "subcommands": {
                "rank": {
                    "name": "rank",
                    "description": "Shows the TOP 10 XP on the server",
                    "response": {
                        "title": "Top 10",
                        "not_found": "XP data were not found on this server."
                    }
                }
            }
        },
        "xpadmin": {
            "name": "xp",
            "description": "XP administration commands (add, remove, reset)",
            "usage": "/xp [action]",
            "subcommands": {
                "add": {
                    "name": "add",
                    "description": "Add XP to a user",
                    "options": {
                        "user": {
                            "name": "user",
                            "description": "User that will receive XP"
                        },
                        "amount": {
                            "name": "amount",
                            "description": "Given XP Amount"
                        }
                    },
                    "response": {
                        "title": "Add XP",
                        "added": "{amount}xp Added to {user}",
                        "error": "An error ocurred!"
                    }
                },
                "remove": {
                    "name": "remove",
                    "description": "Remove XP to a user",
                    "options": {
                        "user": {
                            "name": "user",
                            "description": "User that will loose XP"
                        },
                        "amount": {
                            "name": "amount",
                            "description": "Removed XP Amount"
                        }
                    },
                    "response": {
                        "title": "Remove XP",
                        "removed": "{amount}xp Removed to {user}",
                        "error": "An error ocurred!"
                    }
                },
                "reset": {
                    "name": "reset",
                    "description": "Reset all users XP",
                    "response": {
                        "title": "Reset XP",
                        "reseted": "XP reseted on the server!",
                        "error": "An error ocurred!"
                    }
                }
            }
        },
        "disablexp": {
            "name": "disablexp",
            "description": "Disable a channel from receiving XP",
            "response_title": "Disable XP",
