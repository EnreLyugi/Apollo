            "xp_disabled": "XP disabled on channel <#{channel_id}>",
            "usage": "/disablexp <channel>",
            "options": {
                "channel": {
                    "name": "channel",
                    "description": "Channel that will disable XP"
                }
            }
        },
        "enablexp": {
            "name": "enablexp",
            "description": "Enable a channel from receiving XP",
