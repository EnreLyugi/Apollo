    "commands": {
        "help": {
            "name": "help",
            "description": "Shows available commands and their usage",
            "usage": "/help [command]",
            "options": {
                "command": {
                    "name": "command",
                    "description": "Get detailed help for a specific command"
                }
            },
            "list": {
                "title": "📚 Available Commands",
                "description": "Here are all available commands grouped by category. Use `/help <command>` for detailed information about a specific command.",
                "footer": "Tip: Use the command option to see detailed information about a specific command"
